<Window x:Class="DeviceMonitoringApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DeviceMonitoringApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid ShowGridLines="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Grid.Column="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Width="70" Height="30"
                            Margin="5 5 5 5" Command="{Binding StartCommand}">▶ Старт </Button>
                    <Button Width="70" Margin="0 5 5 5" Command="{Binding StopCommand}">■ Стоп </Button>
                    <Button Margin="0 5 10 5" Command="{Binding ClearStory}">🗑 Очистить историю </Button>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock VerticalAlignment="Center" Margin="0 5 10 5">Состояние: </TextBlock>
                    <TextBlock VerticalAlignment="Center" Margin="0 5 10 5" Text="{Binding SystemStatusText}"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>
           <GroupBox Header="Измерительные устройства">
    <DataGrid ItemsSource="{Binding Device}" AutoGenerateColumns="False" IsReadOnly="True" 
              SelectedItem="{Binding SelectedDevice}">
        <DataGrid.Columns>
            <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="*"/>
            <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="Auto"/>
            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="Auto"/>
            <DataGridTextColumn Header="Значение" Binding="{Binding LastValue, TargetNullValue='—'}" Width="Auto"/>
            <DataGridTextColumn Header="Время" Binding="{Binding LastUpdateTime, StringFormat=\{0:HH:mm:ss\}}" Width="Auto"/>
            <DataGridTextColumn Header="Интервал(мс)" Binding="{Binding PollingInterval}" Width="Auto"/>
        </DataGrid.Columns>
        </DataGrid>
</GroupBox>
            <GroupBox Grid.Column="1" Header="История измерений">
                <DataGrid  ItemsSource="{Binding Measurements}" 
                          AutoGenerateColumns="False" IsReadOnly="True" >
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Время" Binding="{Binding Timestamp, StringFormat=\{0:HH:mm:ss\}}" Width="Auto"/>
                        <DataGridTextColumn Header="Значение" Binding="{Binding Value, TargetNullValue='—'}" Width="*"/>
                        <DataGridTextColumn Header="Успех" Binding="{Binding IsSuccess}" Width="Auto"/>
                        <DataGridTextColumn  Header="Ошибка" Binding="{Binding ErrorMessage}" Width="Auto"/>
                    </DataGrid.Columns>
                </DataGrid>
                </GroupBox>
            
        </Grid>
    </Grid>    
</Window>
